# --- Required for generation ---
REPLICATE_API_TOKEN=

# --- Optional: lock /api/generate to trusted callers (e.g. Next.js BFF only) ---
# REQUIRE_API_KEY=true
# TATTOO_SERVICE_KEY=long-random-secret
# Client / BFF must send header: X-API-Key: <same value>

# --- Rate limits (per IP, in-process per server instance) ---
# GENERATE_RATE_LIMIT=20/minute
# STATUS_RATE_LIMIT=120/minute
# For horizontal scale, use shared Redis/Upstash:
# RATE_LIMIT_STORAGE_URL=redis://default:<password>@<host>:6379
# RATE_LIMIT_STRATEGY=fixed-window

# --- Concurrency guard (per instance) ---
# MAX_CONCURRENT_GENERATIONS=8

# --- Payload guards ---
# MAX_UPLOAD_MB=8
# MAX_ANSWERS_JSON_BYTES=65536
# MAX_CONCEPTS=3
# DEFAULT_CONCEPTS=1

# --- Runtime / CORS ---
# APP_ENV=development
# CORS_ORIGINS=http://localhost:3000
# LOG_PROMPT_BODIES=0
