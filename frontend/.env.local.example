# Browser talks directly to FastAPI (default dev).
NEXT_PUBLIC_API_URL=http://localhost:8000

# Or: use Next.js BFF so the service key never ships to the browser.
# Set on the Next server (not NEXT_PUBLIC_*):
#   TATTOO_BACKEND_URL=http://127.0.0.1:8000
#   TATTOO_SERVICE_KEY=...   # must match backend TATTOO_SERVICE_KEY when REQUIRE_API_KEY=true
# Then:
# NEXT_PUBLIC_USE_BFF=1

# Supabase (Healing Journey stories)
# Project URL (example): https://qqdwopcydjsdabtuybgv.supabase.co
NEXT_PUBLIC_SUPABASE_URL=
# Use server-side service role key for moderation queue inserts + photo uploads.
SUPABASE_SERVICE_ROLE_KEY=
# Optional fallback if you do not want service role in local env:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
